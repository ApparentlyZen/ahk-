local function GetKeyCode(str)
    str = string.upper(str)
    if str == "1" then return Enum.KeyCode.One
    elseif str == "2" then return Enum.KeyCode.Two
    elseif str == "3" then return Enum.KeyCode.Three
    elseif str == "4" then return Enum.KeyCode.Four end
    local success, keyCode = pcall(function() return Enum.KeyCode[str] end)
    return success and keyCode or nil
end

local function GetSlotFromCategory(cat)
    if cat == "Melee" then return "1"
    elseif cat == "Fruit" then return "2"
    elseif cat == "Sword" then return "3"
    elseif cat == "Gun" then return "4" end
    return "1"
end

local function ForceEquipToolByTip(category)
    local char = lp.Character or lp.CharacterAdded:Wait()
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return nil end
    local targetTip = category == "Fruit" and "Blox Fruit" or category

    local currentTool = char:FindFirstChildOfClass("Tool")
    if currentTool and (currentTool.ToolTip == targetTip or currentTool.Name:lower():find(category:lower())) then
        return currentTool
    end

    local foundTool = nil
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") and (tool.ToolTip == targetTip or tool.Name:lower():find(category:lower())) then foundTool = tool break end
    end

    if not foundTool then
        for _, tool in ipairs(lp.Backpack:GetChildren()) do
            if tool:IsA("Tool") and (tool.ToolTip == targetTip or tool.Name:lower():find(category:lower())) then
                hum:EquipTool(tool)
                foundTool = tool
                local startWait = os.clock()
                while not char:FindFirstChild(tool.Name) and os.clock() - startWait < 0.3 do RunService.Heartbeat:Wait() end
                break
            end
        end
    end
    return foundTool
end

local function TriggerMacroExecution()
    if #comboQueue == 0 or getgenv().isComboActive then return end
    getgenv().isComboActive = true -- Allumage du moteur pour le Silent Aim de la V7.4

    for index, item in ipairs(comboQueue) do
        local cat = item.cat
        local data = getgenv().ActivatedSkills[cat][item.skill]
        
        if data and data.active and getgenv().isComboActive then
            -- ÉTAPE 1 : Équipement obligatoire de l'arme
            if getgenv().SelectedMod == "V2" then
                ForceEquipToolByTip(cat)
            else
                local slotStr = GetSlotFromCategory(cat)
                local toolKey = GetKeyCode(slotStr)
                if toolKey then
                    VirtualInputManager:SendKeyEvent(true, toolKey, false, game)
                    VirtualInputManager:SendKeyEvent(false, toolKey, false, game)
                    task.wait(0.04)
                end
            end
            
            -- ÉTAPE 2 : Délai configuré avant attaque
            if data.delay and data.delay > 0 then task.wait(data.delay) end
            
            local skillKey = GetKeyCode(item.skill)
            if skillKey then
                local fired = false
                local spammedCount = 0
                local maxSpamAttempts = 6 -- SÉCURITÉ ANTI-BOUCLE INFINIE
                lastExecutedSkill = nil 

                -- Boucle de spam VIM isolée (Clavier uniquement)
                while not fired and data.active and getgenv().isComboActive and spammedCount < maxSpamAttempts do
                    if getgenv().SelectedMod == "V2" then ForceEquipToolByTip(cat) end
                    
                    if data.hold and data.hold > 0 then
                        VirtualInputManager:SendKeyEvent(true, skillKey, false, game)
                        task.wait(data.hold)
                        VirtualInputManager:SendKeyEvent(false, skillKey, false, game)
                        fired = true -- Pas de spam infini sur les skills à maintien
                    else
                        VirtualInputManager:SendKeyEvent(true, skillKey, false, game)
                        RunService.RenderStepped:Wait()
                        VirtualInputManager:SendKeyEvent(false, skillKey, false, game)
                    end

                    spammedCount = spammedCount + 1

                    -- Fenêtre de vérification synchrone par Namecall (uniquement pour lancers normaux)
                    if not data.hold or data.hold == 0 then
                        local startCheck = os.clock()
                        while os.clock() - startCheck < 0.12 do
                            if lastExecutedSkill == item.skill:upper() then fired = true break end
                            RunService.Heartbeat:Wait()
                        end
                    end

                    if fired then
                        StatusLbl.Text = "✅ [" .. index .. "] Validé : " .. item.skill
                        StatusLbl.TextColor3 = C.green
                    else
                        StatusLbl.Text = "⚡ [" .. index .. "] Spam VIM : " .. item.skill .. " (" .. spammedCount .. "/" .. maxSpamAttempts .. ")"
                        StatusLbl.TextColor3 = C.gold
                        task.wait(0.02)
                    end
                end
            end
            RunService.Heartbeat:Wait()
        end
    end
    
    -- EXTINCTION PROPRE : Le combo s'arrête ici et ne tourne plus du tout en arrière-plan
    task.wait(0.1)
    getgenv().isComboActive = false
    StatusLbl.Text = "Generator engine status: READY"
    StatusLbl.TextColor3 = C.green
end


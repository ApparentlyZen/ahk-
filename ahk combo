-- MOTEUR DE CIBLAGE POUR SILENT AIM & Z-SKILL
-- ====================================================================
local function getHRP(m) return m and m:FindFirstChild("HumanoidRootPart") end

local function isAlly(tp)
    local g = lp:FindFirstChild("PlayerGui") if not g then return false end
    local sf = g:FindFirstChild("Main") and g.Main:FindFirstChild("Allies") and g.Main.Allies:FindFirstChild("Container") and g.Main.Allies.Container:FindFirstChild("Allies") and g.Main.Allies.Container.Allies:FindFirstChild("ScrollingFrame")
    if sf then for _, f in pairs(sf:GetDescendants()) do if f:IsA("ImageButton") and f.Name == tp.Name then return true end end end
    return false
end

local function isEnemy(tp)
    if not tp or tp == lp then return false end
    local mt, tt = lp.Team, tp.Team
    if mt and tt then
        if mt.Name == "Pirates" and tt.Name == "Marines" then return true end
        if mt.Name == "Marines" and tt.Name == "Pirates" then return true end
        if mt.Name == "Pirates" and tt.Name == "Pirates" then return not isAlly(tp) end
        if mt.Name == "Marines" and tt.Name == "Marines" then return false end
    end
    return true
end

local function getClosestTarget()
    local lpHRP = getHRP(lp.Character)
    if not lpHRP then return nil end
    
    local best, bd = nil, 1000
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= lp and isEnemy(pl) and pl.Character then
            local hum = pl.Character:FindFirstChildOfClass("Humanoid")
            local hrp = getHRP(pl.Character)
            if hum and hum.Health > 0 and hrp then
                local d = (hrp.Position - lpHRP.Position).Magnitude
                if d < bd then bd = d best = hrp end
            end
        end
    end
    return best
end

-- ====================================================================
-- LOGIQUE DE PRÉDICTION
-- ====================================================================
local function getPredictedPosition(hrp)
    if not hrp then return nil end    
    local humanoid = hrp.Parent:FindFirstChildOfClass("Humanoid")
    local velocity = hrp.Velocity
    
    if not humanoid or humanoid.WalkSpeed < 5 or velocity.Magnitude > 200 then return hrp.Position end
    return hrp.Position + (velocity * getgenv().PredictionAmount)
end


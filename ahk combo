end

local function syncCheckboxUI(catName, keyName, state)
    local cb = checkboxRegistry[catName .. "_" .. keyName]
    if cb then
        local targetColor = state and T_ACCENT or C.toggleOff
        local targetPos = state and UDim2.new(1, -10, 0.5, -4) or UDim2.new(0, 2, 0.5, -4)
        TweenService:Create(cb.box, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {BackgroundColor3 = targetColor}):Play()
        TweenService:Create(cb.dot, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {Position = targetPos}):Play()
    end
end

local function removeFromQueue(catName, keyName)
    for i, item in ipairs(comboQueue) do
        if item.cat == catName and item.skill == keyName then
            if item.row then item.row:Destroy() end
            table.remove(comboQueue, i)

    })

    ThemeSection:ColorPicker({
        Name = "Couleur du Texte",
        Default = CFG.TextColor,
        Callback = function(color)
            CFG.TextColor = color
            RefreshTheme()
        end
    })

    ThemeSection:ColorPicker({
        Name = "Couleur des Bordures",
        Default = CFG.StrokeColor,
        Callback = function(color)
            CFG.StrokeColor = color
            RefreshTheme()
        end
    })

    -- --- TRANSPARENCE & WINDOW CONTROL ---
    local WindowSection = SettingsPage:Group("UI Customization")

    WindowSection:Slider({
        Name = "Transparence de l'UI",
        Min = 0,
        Max = 100,
        Default = math.floor(CFG.Transparency * 100),
        Unit = "%",
        Callback = function(val)
            CFG.Transparency = val / 100
            RefreshTheme()
        end
    })

    WindowSection:Keybind({
        Name = "Touche du Menu",
        Default = Library.MenuKey,
        Callback = function(key)
            Library.MenuKey = key
        end
    })

    WindowSection:Button({
        Name = "Fermer Complètement l'UI",
        Variant = "Danger",
        Callback = function()
            Library:Unload()
        end
    })
end

function Library:Window(logoUrl)
    MainFrame.Visible = true
    self:CreateFloatingButton(logoUrl)

    local menuConn = UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Library.MenuKey then
            Visible = not Visible
            MainFrame.Visible = Visible
        end
    end)
    table.insert(Library.Connections, menuConn)

    local winObject = {
        Tab = function(_, name, icon) return Library:Tab(name, icon) end,
        CreateSettingsPage = function(_, win) return Library:CreateSettingsPage(win) end,
        Notify = function(_, msg, type) Library:Notify(msg, type) end
    }
    return winObject
end

return Library

        end

        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.Position = UDim2.new(0, icon and 38 or 14, 0, 0)
        lbl.Size = UDim2.new(1, icon and -46 or -22, 1, 0)

                else
                    ListFrame.Visible = false
                end
            end)

            if cfg.Tooltip then AddTooltip(Frame, cfg.Tooltip) end

            -- Initialiser le flag
            if cfg.Flag and Current then Library.Flags[cfg.Flag] = Current end

            local dropdownObj = {

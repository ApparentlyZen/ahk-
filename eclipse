        ClipsDescendants = true
    }, {
        Create("UIStroke", {Color = CFG.AccentColor, Thickness = 2}),
        Create("UICorner", {CornerRadius = UDim.new(1, 0)})
    })

    -- DRAGGABLE
    local DragFloat, DragFloatStart, DragFloatPos = false, nil, nil
    FloatingButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            DragFloat = true
            DragFloatStart = input.Position
            DragFloatPos = FloatingButton.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    DragFloat = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == DragFloat and DragFloat then
            local delta = input.Position - DragFloatStart
            FloatingButton.Position = UDim2.new(DragFloatPos.X.Scale, DragFloatPos.X.Offset + delta.X, DragFloatPos.Y.Scale, DragFloatPos.Y.Offset + delta.Y)
        end
    end)

    -- CHARGEMENT DU LOGO
    if LogoURL and LogoURL ~= "" then
        local imagePath = Library:GetImageFromURL(LogoURL)
        if imagePath then
            Create("ImageLabel", {
                Parent = FloatingButton,
                Size = UDim2.new(1, 0, 1, 0),

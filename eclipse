        for name, _ in pairs(PresetThemes) do
            sApi:Button(name, "Apply the " .. name .. " theme", function()
                applyTheme(name)
                Window:Notify("Theme", name .. " theme applied!", 1.5)
            end)
        end

        sApi:Section("About")
        sApi:Label("_Catalyst " .. _Catalyst.Version)
        sApi:Label(FileSystem.hasIO and "File system: available" or
                   "File system: in-memory only")
        sApi:Label(IS_MOBILE and "Mode: mobile / touch" or
                   "Mode: desktop")
    end

    --==============================================
    -- MOBILE FAB
    --==============================================
    if IS_MOBILE then
        local fab = Instance.new("ImageButton")
        fab.Size = UDim2.new(0, 48, 0, 48)
        fab.Position = UDim2.new(0, 16, 0.5, -24)
        fab.BackgroundColor3 = Theme.Panel
        fab.AutoButtonColor = false
        fab.ScaleType = Enum.ScaleType.Fit
        fab.BackgroundTransparency = 0
        fab.Parent = ScreenGui
        corner(fab, 24)

        local ring = Instance.new("UIStroke")
        ring.Thickness = 2
        ring.Parent = fab
        ring.Color = Theme.Accent
        registerThemeObject(ring, "Accent", "Color")

        local fabUrl = opt.FabImageUrl or
            "https://github.com/ApparentlyZen/image-namelessWare/blob/main/165abdd521328d77324b02ce8a77e090_1780162334922.webp?raw=true"

        taskLib.spawn(function()
            pcall(function()
                if writefile and getcustomasset and game.HttpGet then
                    if not isfile("catalyst_fab.webp") then
                        writefile("catalyst_fab.webp",
                                  game:HttpGet(fabUrl))
                    end
                    fab.Image = getcustomasset("catalyst_fab.webp")
                else
                    fab.Image = "rbxassetid://122765407222246"
                end
            end)
        end)

        fab.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or
               i.UserInputType == Enum.UserInputType.Touch then
                toggleUI()
            end
        end)
    end

    --==============================================
    -- PUBLIC METHODS
    --==============================================
    function Window:SetTheme(theme)
        applyTheme(theme)
    end

    Window.SetAccent = function(c)
        Theme.Accent = c
        applyTheme(Theme)
    end

    Window.Toggle = toggleUI

    Window.Relayout = function()
        relayout(true)
    end

    --==============================================
    -- INIT
    --==============================================
    local didInit = false

    function Window:Init()
        if didInit then return end
        didInit = true
        if settingsPanel then
            cfgDrop.Refresh(getConfigList())
            local meta = readMeta()
            if meta.autoload ~= false and meta.recent then
                local ok = Window:LoadConfig(meta.recent)
                if ok then
                    currentName = meta.recent
                    nameBox.Set(meta.recent)
                    Window:Notify("Config",
                        "Auto-loaded '" .. meta.recent .. "'")
                end
            end
        end
    end

    taskLib.spawn(function()
        taskLib.wait(0.4)
        if alive() and not didInit then Window:Init() end
    end)

    -- Final setup
    relayout(false)
    computeFit()
    tween(uiScale, 0.45, { Scale = targetScale() },
          Enum.EasingStyle.Quart)

    return Window
end

return _Catalyst

function Library:CreateFloatingButton(LogoURL)
    FloatingButton = Create("TextButton", {
        Parent = ScreenGui,
        Size = UDim2.new(0, 50, 0, 50),
        Position = UDim2.new(0.5, 0, 0, 10),
        AnchorPoint = Vector2.new(0.5, 0),

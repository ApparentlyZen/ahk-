function Library:ChangeTheme(key, color)
    CFG[key] = color
    if key == "MainColor" then
        MainFrame.BackgroundColor3 = color
    elseif key == "SecondaryColor" then
        TopBar.BackgroundColor3 = color
    elseif key == "AccentColor" then
        if FloatingButton then
            local stroke = FloatingButton:FindFirstChildOfClass("UIStroke")
            if stroke then stroke.Color = color end
        end
    end
end

function Library:GetConfig()
    return HttpService:JSONEncode(Library.Flags)
end

function Library:LoadConfig(json)
    local success, data = pcall(HttpService.JSONDecode, HttpService, json)
    if success and data then
        for k, v in pairs(data) do
            Library.Flags[k] = v
        end
        return true
    end
    return false
end

function Library:RefreshConfigsList(dropdown)
    if not isfolder("eclipse/Configs") then makefolder("eclipse/Configs") end
    local list = {}
    for _, file in pairs(listfiles("eclipse/Configs")) do
        local name = string.match(file, "([^/]+)%.json$")
        if name then table.insert(list, name) end
    end
    if dropdown and dropdown.Refresh then
        dropdown:Refresh(list)
    end
end

-- ========================================================
--  FENÊTRE PRINCIPALE
-- ========================================================
function Library:Window(logoUrl)
    MainFrame.Visible = true
    self:CreateFloatingButton(logoUrl)

    UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Library.MenuKey then
            Visible = not Visible
            MainFrame.Visible = Visible
        end
    end)

    return {
        Tab = function(_, name, icon) return Library:Tab(name, icon) end,
        CreateSettingsPage = function(_, win) return Library:CreateSettingsPage(win) end,
        Notify = function(_, msg, type) Library:Notify(msg, type) end
    }
end

return Library

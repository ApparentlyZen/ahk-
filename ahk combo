        if orderLabel then
            local data = getgenv().ActivatedSkills[item.cat][item.skill]
            orderLabel.Text = string.format("[%d] %s (%s) — D: %ss | H: %ss", index, item.cat, item.skill, tostring(data.delay), tostring(data.hold))
        end
    end

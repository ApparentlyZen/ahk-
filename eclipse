        if input == DragFloat and DragFloat then
            local delta = input.Position - DragFloatStart
            FloatingButton.Position = UDim2.new(DragFloatPos.X.Scale, DragFloatPos.X.Offset + delta.X, DragFloatPos.Y.Scale, DragFloatPos.Y.Offset + delta.Y)
        end
    end)

    -- Intégration soignée du Logo
    if LogoURL and LogoURL ~= "" then
        local imagePath = Library:GetImageFromURL(LogoURL)
        if imagePath then
            Create("ImageLabel", {
                Parent = FloatingButton,

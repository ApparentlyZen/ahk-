    if getgenv().UseSilentAim and getgenv().isComboActive and not getgenv().isVSkillPaused then
        local HookPosition = getgenv().SilentAimPlayer
        if HookPosition and type(HookPosition) == "vector" then
            if method == "FireServer" and tostring(self) == "RemoteEvent" and tostring(args[1]) ~= "true" and tostring(args[1]) ~= "false" then

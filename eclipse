    })

    RegisterElement(FloatingButton, "BackgroundColor3", "MainColor")
    RegisterElement(FloatingButtonStroke, "StrokeColor", "AccentColor")

    -- Dragging du bouton flottant
    local DragFloat, DragFloatStart, DragFloatPos = false, nil, nil
    FloatingButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            DragFloat = true

                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(0.5, 0, 0.5, 0)
            })
        end
    else
        Create("TextLabel", {
            Parent = FloatingButton,
            Text = "☰",
            TextColor3 = CFG.TextColor,
            TextSize = 22,
            Font = CFG.Font,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0)
        })
    end

    FloatingButton.MouseButton1Click:Connect(function()
        Visible = not Visible
        MainFrame.Visible = Visible
    end)
end

-- ========================================================
--  UNLOAD COMPLET (KILL ALL)
-- ========================================================
function Library:Unload()
    self.Unloaded = true
    for _, conn in pairs(self.Connections) do
        pcall(function() conn.Connection:Disconnect() end)
    end
    for _, thread in pairs(self.Threads) do
        pcall(function() coroutine.close(thread) end)
    end
    for _, s in pairs(self.LoadedScripts) do
        pcall(function() coroutine.close(s.Thread) end)
    end
    self.LoadedScripts = {}
    pcall(function() ScreenGui:Destroy() end)
    self.Flags = {}
    getgenv().Library = nil
    Library = nil
end


-- Dragging Handler for Mobile Toggle
local floatDragging, floatDragStart, floatStartPos
FloatToggle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        floatDragging = true
        floatDragStart = input.Position
        floatStartPos = FloatToggle.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                floatDragging = false
            end
        end)
    end
end)
FloatToggle.InputChanged:Connect(function(input)
    if floatDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - floatDragStart
        FloatToggle.Position = UDim2.new(floatStartPos.X.Scale, floatStartPos.X.Offset + delta.X, floatStartPos.Y.Scale, floatStartPos.Y.Offset + delta.Y)
    end
end)

local function toggleUI()
    local isVisible = not MainFrame.Visible
    MainFrame.Visible = isVisible
    FloatToggle.Visible = not isVisible
end

CloseBtn.MouseButton1Click:Connect(toggleUI)
FloatToggle.MouseButton1Click:Connect(toggleUI)

-- Toggle using keyboard Keycode
UserInputService.InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == Enum.KeyCode.E then
        toggleUI()
    end
end)


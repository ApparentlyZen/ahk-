-- Références globales pour les frames d'UI majeurs afin d'ajuster le thème en temps réel
local MainFrame, TopBar, Sidebar, TopBarLine, SidebarLine

local function Create(class, props, children)
    local inst = Instance.new(class)
    for i, v in pairs(props or {}) do
        inst[i] = v
    end
    for _, child in pairs(children or {}) do
        child.Parent = inst
    end
    return inst
end

local function Tween(obj, props, time, style, dir)
    local t = TweenService:Create(obj, TweenInfo.new(time or 0.2, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), props)
    t:Play()
    return t
end

local function GetTextSize(text, size, font)
    return game:GetService("TextService"):GetTextSize(text, size, font, Vector2.new(10000, 10000))
end

-- Enregistre un élément UI pour pouvoir modifier son apparence en direct via le Theme Manager
local function RegisterElement(instance, propertyType, configKey)
    table.insert(Library.ElementsToTheme, {
        Instance = instance,
        Type = propertyType, -- "BackgroundColor3", "TextColor3", "ImageColor3", "StrokeColor", "Transparency"
        Key = configKey
    })
end

-- Applique les couleurs et transparences actuelles à tous les éléments enregistrés
local function RefreshTheme()
    for _, item in pairs(Library.ElementsToTheme) do
        if item.Instance and item.Instance.Parent then
            if item.Type == "BackgroundColor3" then
                item.Instance.BackgroundColor3 = CFG[item.Key]
            elseif item.Type == "TextColor3" then
                item.Instance.TextColor3 = CFG[item.Key]
            elseif item.Type == "ImageColor3" then
                item.Instance.ImageColor3 = CFG[item.Key]
            elseif item.Type == "StrokeColor" and item.Instance:IsA("UIStroke") then
                item.Instance.Color = CFG[item.Key]
            elseif item.Type == "Transparency" then
                if item.Key == "MainColorTrans" then
                    item.Instance.BackgroundTransparency = CFG.Transparency
                elseif item.Key == "SecondaryColorTrans" then
                    item.Instance.BackgroundTransparency = math.clamp(CFG.Transparency + 0.1, 0, 1)
                end
            end
        end
    end
end

-- ========================================================
--  TÉLÉCHARGEMENT D'IMAGE DEPUIS UNE URL
-- ========================================================
function Library:GetImageFromURL(url)
    if not url or url == "" then return nil end
    if string.find(url, "^rbxassetid://") then return url end

    local fileName = string.gsub(url, "https?://", "")
    fileName = string.gsub(fileName, "[^%w%-%.]", "_")
    local path = "eclipse/Assets/" .. fileName

    if not isfolder("eclipse") then makefolder("eclipse") end
    if not isfolder("eclipse/Assets") then makefolder("eclipse/Assets") end

    if not isfile(path) then
        local success, data = pcall(function()
            return game:HttpGet(url)
        end)
        if success and data then
            writefile(path, data)
            return getcustomasset(path)
        else
            warn("Échec du téléchargement de l'image depuis " .. url)
            return nil
        end
    else
        return getcustomasset(path)
    end
end


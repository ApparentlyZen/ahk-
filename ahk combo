local function clearModuleConnections()
	for _, conn in ipairs(characterConnections) do pcall(function() conn:Disconnect() end) end
	characterConnections = {}
	if aimRenderConn then pcall(function() aimRenderConn:Disconnect() end); aimRenderConn = nil end
	if aimTimeoutTask then pcall(function() task.cancel(aimTimeoutTask) end); aimTimeoutTask = nil end
end

local function pauseSA() getgenv().isVSkillPaused = true end
local function restoreSA() getgenv().isVSkillPaused = false end

local function isValidStopCondition()
    return (currentTool and currentTool.Name == "Shark Anchor" and sharkZActive)
        or (lastTool == "Dough-Dough" and vActive)
        or (currentTool and currentTool.Name == "Cursed Dual Katana" and cursedZActive)
end

local function stopAimlock()
	if not aimlockActive then return end
	aimlockActive = false; godhumanZActive = false
	if aimRenderConn then pcall(function() aimRenderConn:Disconnect() end); aimRenderConn = nil end
	if aimTimeoutTask then pcall(function() task.cancel(aimTimeoutTask) end); aimTimeoutTask = nil end
end

local function startAimlock()
	if not getgenv().ZSkillAimlockEnabled or aimlockActive then return end
	local targetHRP = getClosestTarget()
	if not targetHRP then return end
	aimlockActive = true

	aimRenderConn = RunService.RenderStepped:Connect(function()
		if not getgenv().ZSkillAimlockEnabled then stopAimlock() return end
		if aimlockActive and targetHRP and targetHRP.Parent then
			local cam = workspace.CurrentCamera
			if cam then cam.CFrame = CFrame.lookAt(cam.CFrame.Position, targetHRP.Position) end
		else stopAimlock() end
	end)
	aimTimeoutTask = task.delay(1, function() if aimlockActive then stopAimlock() end end)
end

local function watchDamageCounter()
	task.spawn(function()
		local gui = lp:WaitForChild("PlayerGui"):WaitForChild("Main", 10)
		if not gui then return end
		local dmgCounter = gui:WaitForChild("DmgCounter", 10)
		if not dmgCounter then return end
		local dmgTextLabel = dmgCounter:WaitForChild("Text", 5)
		if not dmgTextLabel then return end

		table.insert(characterConnections, dmgTextLabel:GetPropertyChangedSignal("Text"):Connect(function()
			local dmgText = tonumber(dmgTextLabel.Text) or 0
			if dmgText > 0 then
				if isValidStopCondition() and rightTouchActive then pauseSA() end
				if aimlockActive then stopAimlock() end
			elseif not rightTouchActive then
				restoreSA()
			end
		end))
	end)
end

local function hookTool(tool)
    if not tool then return end
    currentTool = tool; lastTool = tool.Name
    table.insert(characterConnections, tool.AncestryChanged:Connect(function(_, parent)
        if not parent then
            currentTool, lastTool = nil, nil
            sharkZActive, vActive, cursedZActive, godhumanZActive = false, false, false, false
            rightTouchActive = false
            restoreSA()
            stopAimlock()
        end
    end))
end

local function onCharacterAdded(char)
    clearModuleConnections()
    sharkZActive, vActive, cursedZActive, godhumanZActive, rightTouchActive = false, false, false, false, false
    restoreSA()
    stopAimlock()

    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("Tool") then hookTool(child) end
    end
    table.insert(characterConnections, char.ChildAdded:Connect(function(child) if child:IsA("Tool") then hookTool(child) end end))
    watchDamageCounter()
end

lp.CharacterAdded:Connect(onCharacterAdded)
if lp.Character then onCharacterAdded(lp.Character) end


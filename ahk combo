local function mkFrame(parent, size, pos, color, radius) 
    local f = Instance.new("Frame", parent)
    f.Size = size f.Position = pos f.BackgroundColor3 = color f.BorderSizePixel = 0
    if radius and radius > 0 then 
        local c = Instance.new("UICorner", f) c.CornerRadius = UDim.new(0, radius) 
    end
    return f 
end

local function mkLabel(parent, size, pos, text, font, sizeTxt, color, align) 
    local l = Instance.new("TextLabel", parent)
    l.Size = size l.Position = pos l.BackgroundTransparency = 1 l.Text = text
    l.Font = font or Enum.Font.Gotham l.TextSize = sizeTxt l.TextColor3 = color
    l.TextXAlignment = align or Enum.TextXAlignment.Center
    return l 
end

local function addStroke(parent, color, thickness, trans) 
    local s = Instance.new("UIStroke", parent)
    s.Color = color s.Thickness = thickness or 1 s.Transparency = trans or 0
    return s 
end

